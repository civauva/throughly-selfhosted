# Optional overrides for the Throughly stack. You usually need NONE of these — `docker compose up -d`
# works with the built-in defaults and you finish setup in the browser. Copy this file to `.env` only to
# change something:
#
#   cp .env.example .env
#
# Compose reads `.env` automatically — no extra flags needed.

# --- Images ---
# Docker Hub namespace the official images are published under. Leave as-is unless you mirror them yourself.
REGISTRY=laushaner
# TAG=latest                                   # or pin a version, e.g. 1.14.0

# --- How the box is reached ---
# Host port the app is published on (default 8080 → http://localhost:8080).
HTTP_PORT=8080
HTTPS_PORT=8443
# Leave APP_ADDRESS as ':80' for plain HTTP. Set it to your domain to get automatic HTTPS (Let's Encrypt);
# then set HTTP_PORT=80 and HTTPS_PORT=443 so the public ports are reachable.
APP_ADDRESS=:80

# --- Database (the bundled Postgres; override only to use your own server) ---
DB_NAME=throughly
DB_USER=throughly
DB_PASSWORD=throughly
# DB_HOST=postgres
# DB_PORT=5432

# --- Email (optional; you can also set this in-app under Administration → Email) ---
# SMTP_FROM=no-reply@example.com
# APP_BASE_URL=https://throughly.example.com   # used for links inside outbound emails

# --- Misc ---
# LOG_LEVEL=Warning
# MAIL_OBSERVER=false                          # IMAP bill-import poller (mailboxes configured in-app)
